# GameVote API Environment Variables
# Copy this file to .env and adjust the values for your local development

# Server Configuration
SERVER_PORT=8080

# SurrealDB Configuration
SURREAL_WS=ws://localhost:8000/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=gamevote
SURREAL_DB=gamevote

# Logging Level (optional)
# LOG_LEVEL=info

# Example of how to use:
# 1. Copy this file to .env: cp .env.example .env
# 2. Modify the values in .env for your local setup
# 3. The .env file will be automatically loaded by godotenv.Load()