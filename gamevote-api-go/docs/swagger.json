                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "parties"
                ],
                "summary": "Add an option",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Party Code",
                        "name": "code",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Option Details",
                        "name": "option",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.PartyOption"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.PartyOption"
