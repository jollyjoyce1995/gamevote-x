        "/parties/{code}/options/{gameName}": {
            "delete": {
                "description": "Delete an option from a party by its name",
                "tags": [
                    "parties"
                ],
                "summary": "Delete an option",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Party Code",
                        "name": "code",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Game Name",
                        "name": "gameName",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
