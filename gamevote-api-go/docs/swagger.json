                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "parties"
                ],
                "summary": "Add an attendee",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Party Code",
                        "name": "code",
                        "in": "path",
