            "get": {
                "description": "Opens a Server-Sent Events stream for real-time party updates",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "parties"
                ],
                "summary": "SSE stream for a party",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Party Code",
                        "name": "code",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Username of the connected client",
                        "name": "username",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
