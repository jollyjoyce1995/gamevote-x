                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "polls"
                ],
                "summary": "Submit a vote",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Poll ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Attendee Name",
                        "name": "attendee",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Choices (-1, 0, or 1)",
