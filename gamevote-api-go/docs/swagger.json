        "/parties/{code}/beers": {
            "post": {
                "description": "Add a beer for an attendee in a party",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "parties"
                ],
                "summary": "Add a beer",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Party Code",
                        "name": "code",
                        "in": "path",
